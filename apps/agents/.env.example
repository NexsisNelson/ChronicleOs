# Agents App Environment Template
# Copy to .env and fill in your actual values

# Walrus Configuration
WALRUS_ENDPOINT=https://walrus-devnet.sui.io
WALRUS_PRIVATE_KEY=your_sui_private_key_here
WALRUS_GAS_BUDGET=100000000

# MemWal Configuration
MEMWAL_ENDPOINT=http://localhost:8000
MEMWAL_API_KEY=your_memwal_api_key

# LLM Configuration (choose one or both)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
DEEPSEEK_API_KEY=your-deepseek-key

# LLM Model Selection
PRIMARY_MODEL=gpt-4o
REASONING_MODEL=o1
FALLBACK_MODEL=claude-3-5-sonnet

# Logging
LOG_LEVEL=INFO
DEBUG=False

# Workflow Configuration
SESSION_ID=session_default
MAX_ITERATIONS=10
TIMEOUT_SECONDS=3600

# Data Storage (local before Walrus integration)
LOCAL_DATA_DIR=./data
ARTIFACTS_DIR=./artifacts
LOGS_DIR=./logs
