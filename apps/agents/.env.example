# Agents App Environment Template
# Copy to .env and fill in your actual values

# Walrus Configuration
WALRUS_ENDPOINT=https://publisher.walrus-testnet.walrus.space
WALRUS_PUBLISHER_ENDPOINT=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_ENDPOINT=https://aggregator.walrus-testnet.walrus.space
WALRUS_UPLOAD_PATH=/v1/blobs
WALRUS_DOWNLOAD_PATH=/v1/blobs/{cid}
WALRUS_METADATA_PATH=/v1/blobs/{cid}/metadata
WALRUS_GAS_BUDGET=100000000

# MemWal Configuration
# Use http://memwal:8000 when running inside Docker Compose,
# or http://localhost:8000 when running locally on the host.
MEMWAL_ENDPOINT=http://localhost:8000

# Optional hosted Walrus Memory configuration
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=

# LLM Configuration (choose one or both)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
DEEPSEEK_API_KEY=your-deepseek-key

# LLM Model Selection
PRIMARY_MODEL=gpt-4o
REASONING_MODEL=o1
FALLBACK_MODEL=claude-3-5-sonnet

# Logging
LOG_LEVEL=INFO
DEBUG=False

# Workflow Configuration
SESSION_ID=session_default
MAX_ITERATIONS=10
TIMEOUT_SECONDS=3600

# Data Storage (local before Walrus integration)
LOCAL_DATA_DIR=./data
ARTIFACTS_DIR=./artifacts
LOGS_DIR=./logs
