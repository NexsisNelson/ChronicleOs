# Agents environment for testnet deployment
WALRUS_ENDPOINT=https://walrus-testnet.sui.io
WALRUS_UPLOAD_PATH=/blobs
WALRUS_DOWNLOAD_PATH=/blobs/{cid}
WALRUS_METADATA_PATH=/blobs/{cid}/metadata
WALRUS_PRIVATE_KEY=<your-sui-private-key>
WALRUS_GAS_BUDGET=100000000

# MemWal is still run locally in this compose setup
MEMWAL_ENDPOINT=http://memwal:8000
MEMWAL_API_KEY=<your-memwal-api-key>

# LLM / model configuration
OPENAI_API_KEY=<your-openai-key>
PRIMARY_MODEL=gpt-4o
REASONING_MODEL=o1
FALLBACK_MODEL=claude-3-5-sonnet

# Logging and workflow
LOG_LEVEL=INFO
DEBUG=False
SESSION_ID=testnet_workflow
MAX_ITERATIONS=20
TIMEOUT_SECONDS=7200

# Data storage
LOCAL_DATA_DIR=./data
ARTIFACTS_DIR=./artifacts
LOGS_DIR=./logs
