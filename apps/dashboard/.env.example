# Dashboard Environment Template

# Use http://localhost:8001 for a local Walrus gateway when running via Docker Compose.
NEXT_PUBLIC_WALRUS_GATEWAY=http://localhost:8001
# Dashboard MemWal API bridge backed by the server-side SDK when available.
NEXT_PUBLIC_MEMWAL_API=/api/memwal
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_ENABLE_DEV_TOOLS=false
