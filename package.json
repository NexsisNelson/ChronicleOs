{
  "name": "chronicle-os",
  "version": "0.1.0",
  "description": "Decentralized multi-agent R&D lab with Walrus + MemWal + Developer Dashboard",
  "private": true,
  "packageManager": "npm@8.19.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "bootstrap": "node scripts/bootstrap.mjs",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.19.4"
  }
}
